# Copy this file to /opt/law-app/.env on the ECS host and replace placeholders.
# Frontend/backend domains are intentionally not fixed yet.

APP_ENV=production
PROJECT_NAME=law-app
VERSION=0.1.0
DEBUG=false
API_V1_STR=/api/v1

# Keep permissive while domains are undecided. Replace with real origins later,
# for example: ["https://h5.example.com","https://api.example.com"]
ALLOWED_ORIGINS=["*"]

STORAGE_BACKEND=postgres
UPLOAD_DIR=/app/uploads
UPLOADS_DIR=./uploads

MOCK_OTP_CODE=123456
OTP_EXPIRE_MINUTES=5

# Aliyun SMS. Use a least-privilege RAM user and approved sign/templates.
SMS_ENABLED=true
SMS_PROVIDER=aliyun
SMS_CODE_TTL=5m
SMS_CODE_LENGTH=6
SMS_SEND_COOLDOWN=60s
SMS_MAX_ATTEMPTS=5
ALIYUN_SMS_ACCESS_KEY_ID=replace-with-ram-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=replace-with-ram-access-key-secret
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=replace-with-approved-sign-name
ALIYUN_SMS_TEMPLATE_REGISTER=SMS_replace_with_register_template
ALIYUN_SMS_TEMPLATE_LOGIN=SMS_replace_with_login_template
ALIYUN_SMS_TEMPLATE_CODE_PARAM=code
ALIYUN_SMS_REQUEST_TIMEOUT=5s
TOKEN_EXPIRE_DAYS=30
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

POSTGRES_HOST=postgres
POSTGRES_DB=law_app
POSTGRES_USER=law_app
POSTGRES_PORT=5432
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

OPENAI_API_BASE=
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=
DEFAULT_LLM_TEMPERATURE=0.7

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Optional initial admin bootstrap on API startup.
ADMIN_PHONE=
ADMIN_NAME=
ADMIN_PASSWORD=replace-with-a-strong-admin-password

LOG_LEVEL=INFO
LOG_FORMAT=console

# Runtime/deploy controls.
WEB_PORT=80
LAW_APP_TAG=latest
VITE_API_BASE_URL=/api/v1
