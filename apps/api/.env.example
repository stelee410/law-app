# Application Settings
APP_ENV=development
PROJECT_NAME=law-app
VERSION=0.1.0
DEBUG=true
API_V1_STR=/api/v1
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8080","http://192.168.200.131:3000","http://192.168.200.131:3001"]

# Storage
STORAGE_BACKEND=postgres
UPLOAD_DIR=uploads

# Auth
MOCK_OTP_CODE=123456
OTP_EXPIRE_MINUTES=5

# SMS (mock for local development; use aliyun for real delivery)
SMS_ENABLED=true
SMS_PROVIDER=mock
SMS_CODE_TTL=5m
SMS_CODE_LENGTH=6
SMS_SEND_COOLDOWN=60s
SMS_MAX_ATTEMPTS=5
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_REGION_ID=cn-hangzhou
ALIYUN_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_REGISTER=
ALIYUN_SMS_TEMPLATE_LOGIN=
ALIYUN_SMS_TEMPLATE_CODE_PARAM=code
ALIYUN_SMS_REQUEST_TIMEOUT=5s
TOKEN_EXPIRE_DAYS=30
JWT_SECRET_KEY=server-7f3a9c2e1b8d4056a1c9e7f2b3d6048c5e9a1f7b2c4d8e60
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30
ADMIN_PHONE=13600000000
ADMIN_NAME=平台管理员
ADMIN_PASSWORD=change-me-admin-password

# Postgres
POSTGRES_HOST=192.168.200.131
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=change-me
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# OpenAI-compatible LLM
OPENAI_API_BASE=http://10.0.23.119:8180/v1
OPENAI_API_KEY=sk-placeholder
DEFAULT_LLM_MODEL=Qwen3-Coder-Next-REAM-AWQ-4bit
DEFAULT_LLM_TEMPERATURE=0.9

# Observability
LANGFUSE_PUBLIC_KEY=pk-lf-placeholder
LANGFUSE_SECRET_KEY=sk-lf-placeholder
LANGFUSE_HOST=https://cloud.langfuse.com

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
